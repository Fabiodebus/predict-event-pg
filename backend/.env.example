# Database — use asyncpg driver
DATABASE_URL=postgresql+asyncpg://predict:predict@localhost:5432/predict

# Redis — broker and result backend must be on separate Redis DB indexes for Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=predict-customer-files-dev
# AWS credentials are resolved via environment, ~/.aws/credentials, or IAM role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173"]

# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Third-party integrations
CRUSTDATA_API_KEY=
BROWSER_USE_API_KEY=
UNIPILE_API_KEY=
UNIPILE_BASE_URL=https://api.unipile.com
